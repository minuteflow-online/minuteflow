{
  "manifest_version": 3,
  "name": "MinuteFlow Screen Capture",
  "version": "1.1.2",
  "description": "Silent screenshot capture for MinuteFlow time tracking. Captures active tab only — no bookmarks, no personal data leaking.",
  "update_url": "https://minuteflow.click/extension-updates.xml",
  "permissions": [
    "activeTab",
    "tabs",
    "alarms",
    "storage",
    "unlimitedStorage",
    "notifications"
  ],
  "host_permissions": [
    "https://tdaurfsglbxoutvdybjm.supabase.co/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "toast.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
